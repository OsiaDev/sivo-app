<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/white"
    app:cardBackgroundColor="@color/acta_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:id="@+id/layoutTipoApuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tipoApuestaNombreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:lines="2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/acta_text_title"
                style="@style/ActaTextStyle"
                tools:text="SILLAS DE BINGO CON APUESTA HASTA \$250" />

            <TextView
                android:id="@+id/codigoApuestaText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:lines="1"
                android:textSize="14sp"
                android:textColor="@color/acta_text_title"
                style="@style/ActaTextStyle"
                tools:text="Código: 8" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutSillas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutTipoApuesta">

            <TextView
                android:id="@+id/sillasText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:lines="1"
                android:textSize="14sp"
                android:textColor="@color/acta_text_title"
                style="@style/ActaTextStyle"
                tools:text="Sillas: 200" />

            <TextView
                android:id="@+id/insCodigoText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:lines="1"
                android:textSize="14sp"
                android:textColor="@color/acta_text_title"
                style="@style/ActaTextStyle"
                tools:text="Ins: 659017" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>