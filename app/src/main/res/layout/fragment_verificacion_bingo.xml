<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:padding="16dp"
    tools:context=".ui.establecimiento.bingo.VerificacionBingoFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingTop="2dp"
            android:text="@string/verificacion_bingo_subtitle"
            android:textColor="@color/fragment_subtitle_color"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Pregunta 1: Cartones por módulos (texto libre) -->
        <TextView
            android:id="@+id/pregunta1Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/bingo_pregunta1"
            android:textColor="@color/text_title_detail"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/cartonesModulosLayout"
            style="@style/Form.InputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bingo_cartones_hint"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pregunta1Label">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/cartonesModulosEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="text"
                android:maxLength="100"
                android:padding="15dp"
                android:textColor="@color/input_text_color"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 2: Sistema tecnológico (Si/No/NA) -->
        <TextView
            android:id="@+id/pregunta2Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/bingo_pregunta2"
            android:textColor="@color/text_title_detail"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cartonesModulosLayout" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/sistemaTecnologicoLayout"
            style="@style/Widget.Coljuegos.TextInputLayout.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/seleccione_opcion"
            app:endIconMode="dropdown_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pregunta2Label">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/sistemaTecnologicoSpinner"
                style="@style/Widget.Coljuegos.MaterialAutoCompleteTextView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:completionThreshold="1"
                android:dropDownWidth="wrap_content"
                android:inputType="none"
                android:padding="15dp"
                android:textColor="@color/input_text_color"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 3: Sistema interconectado (Si/No/NA) -->
        <TextView
            android:id="@+id/pregunta3Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/bingo_pregunta3"
            android:textColor="@color/text_title_detail"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sistemaTecnologicoLayout" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/sistemaInterconectadoLayout"
            style="@style/Widget.Coljuegos.TextInputLayout.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/seleccione_opcion"
            app:endIconMode="dropdown_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pregunta3Label">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/sistemaInterconectadoSpinner"
                style="@style/Widget.Coljuegos.MaterialAutoCompleteTextView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:completionThreshold="1"
                android:dropDownWidth="wrap_content"
                android:inputType="none"
                android:padding="15dp"
                android:textColor="@color/input_text_color"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 4: Eventos especiales (Si/No/NA) -->
        <TextView
            android:id="@+id/pregunta4Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/bingo_pregunta4"
            android:textColor="@color/text_title_detail"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sistemaInterconectadoLayout" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/eventosEspecialesLayout"
            style="@style/Widget.Coljuegos.TextInputLayout.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/seleccione_opcion"
            app:endIconMode="dropdown_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pregunta4Label">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/eventosEspecialesSpinner"
                style="@style/Widget.Coljuegos.MaterialAutoCompleteTextView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:completionThreshold="1"
                android:dropDownWidth="wrap_content"
                android:inputType="none"
                android:padding="15dp"
                android:textColor="@color/input_text_color"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 5: Tipo balotera (Manual / Electroneumática) -->
        <TextView
            android:id="@+id/pregunta5Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/bingo_pregunta5"
            android:textColor="@color/text_title_detail"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/eventosEspecialesLayout" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tipoBaloterLayout"
            style="@style/Widget.Coljuegos.TextInputLayout.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/seleccione_opcion"
            app:endIconMode="dropdown_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pregunta5Label">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/tipoBaloterSpinner"
                style="@style/Widget.Coljuegos.MaterialAutoCompleteTextView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:completionThreshold="1"
                android:dropDownWidth="wrap_content"
                android:inputType="none"
                android:padding="15dp"
                android:textColor="@color/input_text_color"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 6: Valor cartón expuesto (Si/No/NA) -->
        <TextView
            android:id="@+id/pregunta6Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/bingo_pregunta6"
            android:textColor="@color/text_title_detail"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tipoBaloterLayout" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/valorCartonExpuestoLayout"
            style="@style/Widget.Coljuegos.TextInputLayout.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/seleccione_opcion"
            app:endIconMode="dropdown_menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pregunta6Label">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/valorCartonExpuestoSpinner"
                style="@style/Widget.Coljuegos.MaterialAutoCompleteTextView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:completionThreshold="1"
                android:dropDownWidth="wrap_content"
                android:inputType="none"
                android:padding="15dp"
                android:textColor="@color/input_text_color"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botones de navegación -->
        <LinearLayout
            android:id="@+id/layoutBotones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/valorCartonExpuestoLayout">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnterior"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:paddingVertical="16dp"
                android:text="@string/verificacion_contractual_anterior"
                android:textSize="16sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/login_button_color_init"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSiguiente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:paddingVertical="16dp"
                android:text="@string/verificacion_contractual_siguiente"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/login_button_color_init"
                app:cornerRadius="8dp"
                app:elevation="4dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>